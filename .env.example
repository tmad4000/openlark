# Node
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# PostgreSQL
DATABASE_URL=postgres://openlark:openlark@localhost:5432/openlark
# For docker-compose.prod.yml, use these instead:
# POSTGRES_DB=openlark
# POSTGRES_USER=openlark
# POSTGRES_PASSWORD=changeme_db_password

# Redis
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=changeme_redis_password

# JWT
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=openlark
S3_SECRET_KEY=openlark123
S3_BUCKET=openlark
S3_REGION=us-east-1

# Meilisearch
MEILI_URL=http://localhost:7700
MEILI_KEY=openlark-dev-key

# AI Features (optional)
AI_PROVIDER=mock
# AI_PROVIDER=openai | anthropic | ollama | mock
OPENAI_API_KEY=
# OLLAMA_URL=http://localhost:11434

# Public URLs (for docker-compose.prod.yml)
# PUBLIC_API_URL=http://localhost:3001
# PUBLIC_PORT=80

# LiveKit (optional, for video meetings)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=
