# ─── OpenLark Production Environment ────────────────────────────
# Copy this file to .env and fill in the values before running:
#   docker compose -f docker-compose.prod.yml up

# ─── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=openlark
POSTGRES_PASSWORD=changeme_postgres_password
POSTGRES_DB=openlark

# ─── Redis ──────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password

# ─── Application Secrets ────────────────────────────────────────
JWT_SECRET=changeme_jwt_secret_at_least_32_chars

# ─── S3 / MinIO Object Storage ─────────────────────────────────
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=changeme_minio_password
S3_BUCKET=openlark

# ─── LiveKit (Video/Audio) ──────────────────────────────────────
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=changeme_livekit_secret

# Public URL for LiveKit (used by browser clients)
PUBLIC_LIVEKIT_URL=ws://localhost:7880

# ─── Public Access ──────────────────────────────────────────────
# Port that nginx listens on (the main entry point)
PUBLIC_PORT=80

# ─── AI Features (optional) ────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ─── Email (optional) ──────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=changeme
# SMTP_FROM=OpenLark <noreply@example.com>

# ─── Translation (optional) ────────────────────────────────────
# DEEPL_API_KEY=...
